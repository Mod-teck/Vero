### 1. New Models

---

#### [NEW] [CustomerOrder.js](file:///d:/Vero-20-4vvv/models/CustomerOrder.js)

New Mongoose schema for customer-submitted orders, completely separate from the existing admin `Order` model:

```javascript
{
  orderCode: String,           // Auto-generated via Counter (e.g. "ORD-20260421-5")
  
  // Customer Info
  customer: {
    fullName: String,          // Required, sanitized
    primaryPhone: String,      // Required, Egyptian format validation
    secondaryPhone: String,    // Optional
  },
  
  // Address
  address: {
    location: {
      lat: Number,
      lng: Number,
    },
    governorate: String,       // Required, from allowed list
    area: String,              // Required, from allowed list per governorate
    detailedAddress: String,   // Required, sanitized textarea
    landmark: String,          // Optional
    buildingName: String,      // Required
    floorNumber: String,       // Required
    apartmentNumber: String,   // Required
  },
  
  // Cart Items
  items: [{
    productId: ObjectId (ref Product),
    productName: String,
    selectedSize: String,
    quantity: Number,
    priceBeforeDiscount: Number,
    priceAfterDiscount: Number,
  }],
  
  // Pricing
  pricing: {
    totalBeforeDiscount: Number,
    totalAfterDiscount: Number,
    promoCode: String | null,
    promoDiscount: Number,     // Amount deducted by promo
    finalTotal: Number,
  },
  
  // Payment
  payment: {
    method: String,            // 'instapay' | 'mobile_wallet' | 'cash_on_delivery'
    depositRequired: Number,   // 50% of total for COD
    paymentProofPath: String,  // File path for uploaded screenshot
  },
  
  status: String,              // Default: 'pending_review'
  timestamps: true
}
```

Indexes: `{ status: 1, createdAt: -1 }`, `{ orderCode: 1 }` (unique), `{ 'customer.primaryPhone': 1 }`

