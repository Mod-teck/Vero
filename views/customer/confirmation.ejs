<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="<%= description %>" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/customer.css" />
  </head>
  <body>
    <div class="page-container">
      <!-- Step Indicator (all complete) -->
      <div class="step-indicator">
        <div class="step completed">
          <div class="step-circle">✓</div>
          <span class="step-label">البيانات</span>
        </div>
        <div class="step-line active-line"></div>
        <div class="step completed">
          <div class="step-circle">✓</div>
          <span class="step-label">المنتجات</span>
        </div>
        <div class="step-line active-line"></div>
        <div class="step completed">
          <div class="step-circle">✓</div>
          <span class="step-label">الدفع</span>
        </div>
        <div class="step-line active-line"></div>
        <div class="step completed">
          <div class="step-circle">✓</div>
          <span class="step-label">التأكيد</span>
        </div>
      </div>

      <div class="confirmation-container">
        <!-- Success Animation -->
        <div class="success-icon">
          <svg class="checkmark" viewBox="0 0 52 52">
            <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
            <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
          </svg>
        </div>

        <h1 class="confirmation-title">تم تقديم طلبك بنجاح!</h1>

        <div class="order-details-card">
          <div class="detail-row">
            <span class="detail-label">رقم الطلب</span>
            <span class="detail-value" id="order-code">---</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">الحالة</span>
            <span class="detail-value status-badge">قيد المراجعة</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">الإجمالي</span>
            <span class="detail-value" id="order-total">0 ج.م</span>
          </div>
          <div class="detail-row" id="deposit-row" style="display:none;">
            <span class="detail-label">العربون المطلوب</span>
            <span class="detail-value highlight" id="order-deposit">0 ج.م</span>
          </div>
        </div>

        <div class="tracking-info">
          <p>يمكنك تتبع طلبك برقم الطلب أعلاه.</p>
          <p class="tracking-token">رمز التتبع: <code id="tracking-token">---</code></p>
        </div>

        <a href="/order" class="btn-primary btn-full">
          <span class="btn-text">العودة للصفحة الرئيسية</span>
        </a>
      </div>
    </div>

    <script nonce="<%= nonce %>">
      // Read order data from sessionStorage (set by payment.js after successful submission)
      document.addEventListener('DOMContentLoaded', function() {
        try {
          const orderData = JSON.parse(sessionStorage.getItem('vero_order_result') || '{}');
          if (orderData.orderCode) {
            document.getElementById('order-code').textContent = orderData.orderCode;
          }
          if (orderData.trackingToken) {
            document.getElementById('tracking-token').textContent = orderData.trackingToken;
          }
          if (orderData.finalTotal) {
            document.getElementById('order-total').textContent = orderData.finalTotal + ' ج.م';
          }
          if (orderData.depositRequired && orderData.depositRequired > 0) {
            document.getElementById('deposit-row').style.display = 'flex';
            document.getElementById('order-deposit').textContent = orderData.depositRequired + ' ج.م';
          }
          // Clean up
          sessionStorage.removeItem('vero_order_result');
          sessionStorage.removeItem('vero_session_id');
          sessionStorage.removeItem('vero_csrf_token');
        } catch (e) { /* ignore */ }
      });
    </script>
  </body>
</html>
