<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="<%= description %>" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/customer.css" />
  </head>
  <body>
    <div class="page-container">
      <!-- Step Indicator -->
      <div class="step-indicator">
        <div class="step completed">
          <div class="step-circle">✓</div>
          <span class="step-label">البيانات</span>
        </div>
        <div class="step-line active-line"></div>
        <div class="step active">
          <div class="step-circle">2</div>
          <span class="step-label">المنتجات</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-circle">3</div>
          <span class="step-label">الدفع</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-circle">4</div>
          <span class="step-label">التأكيد</span>
        </div>
      </div>

      <div class="page-header">
        <a href="/order/info" class="back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </a>
        <h1 class="page-title">اختر منتجاتك</h1>
      </div>

      <div class="products-layout">
        <!-- Products Grid (Left) -->
        <div class="products-section">
          <div id="products-loading" class="loading-spinner">
            <div class="spinner"></div>
            <p>جاري تحميل المنتجات...</p>
          </div>
          <div id="products-grid" class="products-grid"></div>
        </div>

        <!-- Cart + Summary (Right) -->
        <div class="cart-section">
          <!-- Cart Table -->
          <div class="cart-card">
            <h2 class="card-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              السلة
            </h2>
            <div id="cart-empty" class="cart-empty">
              <p>السلة فارغة</p>
            </div>
            <div id="cart-table-wrap" class="cart-table-wrap" style="display:none;">
              <table class="cart-table">
                <thead>
                  <tr>
                    <th>المنتج</th>
                    <th>المقاس</th>
                    <th>الكمية</th>
                    <th>السعر</th>
                    <th>بعد الخصم</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="cart-body"></tbody>
              </table>
            </div>
          </div>

          <!-- Summary -->
          <div class="summary-card">
            <h2 class="card-title">ملخص الطلب</h2>
            <div class="summary-row">
              <span>الإجمالي قبل الخصم</span>
              <span id="total-before">0 ج.م</span>
            </div>
            <div class="summary-row">
              <span>الإجمالي بعد الخصم</span>
              <span id="total-after" class="highlight">0 ج.م</span>
            </div>

            <div class="promo-section">
              <div class="promo-input-wrap">
                <input type="text" id="promo-code" class="form-input" placeholder="كود الخصم" maxlength="20" dir="ltr" />
                <button type="button" id="btn-apply-promo" class="btn-secondary" disabled>تطبيق</button>
              </div>
              <div id="promo-message" class="promo-message"></div>
            </div>

            <div class="summary-row summary-total">
              <span>الإجمالي النهائي</span>
              <span id="final-total">0 ج.م</span>
            </div>

            <button type="button" id="btn-to-payment" class="btn-primary btn-full" disabled>
              <span class="btn-text">تأكيد الطلب</span>
              <span class="btn-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <script src="/js/productOrder.js"></script>
  </body>
</html>
