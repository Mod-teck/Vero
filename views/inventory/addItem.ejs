<%- include('../layouts/header', { title: title, description: description }) %>

<main class="dashboard-container">
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>

  <div class="category-page" style="width:100%;max-width:700px;margin:0 auto;position:relative;z-index:1;">

    <div class="category-header">
      <nav class="breadcrumb">
        <a href="/dashboard">لوحة التحكم</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory">المخزون</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">إضافة صنف</span>
      </nav>
      <h1>إضافة صنف جديد</h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="message-area error" style="display:block;margin-bottom:20px;background:var(--error);color:white;padding:12px 16px;border-radius:8px;">
        <%= error %>
      </div>
    <% } %>

    <section class="dashboard-section">
      <form
        action="/inventory/add-item?_csrf=<%= csrfToken %>"
        method="POST"
        enctype="multipart/form-data"
        id="addItemForm"
        style="display:flex;flex-direction:column;gap:20px;"
        novalidate
      >

        <!-- Name -->
        <div class="form-group">
          <label for="name" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            اسم الصنف <span style="color:var(--error);">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="200"
            value="<%= typeof formData !== 'undefined' ? (formData.name || '') : '' %>"
            placeholder="مثال: بنطلون جينز"
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;"
          >
        </div>

        <!-- Season -->
        <div class="form-group">
          <label for="season" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            الموسم <span style="color:var(--error);">*</span>
          </label>
          <select
            id="season"
            name="season"
            required
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;"
          >
            <option value="" disabled <%= (typeof formData === 'undefined' || !formData.season) ? 'selected' : '' %>>اختر الموسم</option>
            <% [['summer','صيف'],['winter','شتاء'],['autumn','خريف'],['spring','ربيع']].forEach(function(opt){ %>
              <option value="<%= opt[0] %>" <%= (typeof formData !== 'undefined' && formData.season === opt[0]) ? 'selected' : '' %>><%= opt[1] %></option>
            <% }); %>
          </select>
        </div>

        <!-- Gender pre-set from URL query param (?gender=men) -->
        <input type="hidden" name="gender" value="<%= typeof defaultGender !== 'undefined' ? defaultGender : '' %>">

        <!-- Image -->
        <div class="form-group">
          <label for="image" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            صورة الصنف (اختياري — أقصى حجم 1 ميجابايت)
          </label>
          <input
            type="file"
            id="image"
            name="image"
            accept="image/*"
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;cursor:pointer;"
          >
          <div id="imagePreview" style="margin-top:10px;display:none;">
            <img id="previewImg" src="" alt="معاينة" style="max-width:160px;border-radius:8px;border:1px solid var(--surface-glass-border);">
          </div>
        </div>

        <button
          type="submit"
          id="submitBtn"
          style="background:var(--primary);color:white;border:none;padding:16px;border-radius:8px;font-weight:bold;cursor:pointer;font-size:1.1rem;"
        >
          إضافة الصنف
        </button>

      </form>
    </section>
  </div>
</main>

<script nonce="<%= nonce %>">
  // Image preview
  document.getElementById('image').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    if (!file.type.startsWith('image/')) {
      alert('يجب أن يكون الملف صورة');
      this.value = '';
      return;
    }
    if (file.size > 1 * 1024 * 1024) {
      alert('حجم الصورة يجب أن يكون أقل من 1 ميجابايت');
      this.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = function (e) {
      document.getElementById('previewImg').src = e.target.result;
      document.getElementById('imagePreview').style.display = 'block';
    };
    reader.readAsDataURL(file);
  });

  // Basic client-side validation
  document.getElementById('addItemForm').addEventListener('submit', function (e) {
    var name   = document.getElementById('name').value.trim();
    var season = document.getElementById('season').value;
    var gender = document.querySelector('input[name="gender"]');
    var genderVal = gender ? gender.value : '';
    if (!name || !season || !genderVal) {
      e.preventDefault();
      alert('يرجى ملء جميع الحقول المطلوبة');
    }
  });
</script>

<%- include('../layouts/footer') %>
