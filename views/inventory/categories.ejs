<%- include('../layouts/header', { title: title, description: description }) %>

<main class="dashboard-container" data-csrf="<%= csrfToken %>">
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>

  <div class="inv-page" style="width:100%;max-width:900px;margin:0 auto;position:relative;z-index:1;">

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/dashboard">لوحة التحكم</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/inventory">المخزون</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current"><%= sectionLabel %></span>
    </nav>

    <!-- Page Header -->
    <div class="inv-page-header">
      <div>
        <h1 class="inv-page-title"><%= sectionLabel %></h1>
        <p class="inv-page-subtitle"><%= total %> صنف</p>
      </div>
      <a href="/inventory/add-item?gender=<%= sectionSlug %>" class="inv-btn inv-btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        إضافة صنف
      </a>
    </div>

    <!-- Section Quick Switch -->
    <div class="inv-tabs">
      <% sections.forEach(function(s) { %>
        <a
          href="/inventory/<%= s.slug %>"
          class="inv-tab<%= sectionSlug === s.slug ? ' inv-tab--active' : '' %>"
        >
          <%= s.label %>
        </a>
      <% }) %>
    </div>

    <!-- Categories List -->
    <section class="inv-section" style="margin-top:24px;">
      <div class="inv-section-header">
        <h2 class="inv-section-title">الأصناف</h2>
        <span class="inv-count"><%= total %> صنف</span>
      </div>

      <% if (items && items.length > 0) { %>
        <div class="inv-list">
          <% items.forEach(function(item) { %>
            <div class="inv-card inv-card--row" style="flex-wrap:wrap;">
              <div class="inv-card-img">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                <% } else { %>
                  <div class="inv-card-placeholder">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                <% } %>
              </div>
              <div class="inv-card-body">
                <span class="inv-card-title"><%= item.name %></span>
                <div class="inv-card-meta">
                  <span class="inv-badge inv-badge--season">
                    <%= item.season === 'summer' ? 'صيف' : item.season === 'winter' ? 'شتاء' : item.season === 'autumn' ? 'خريف' : 'ربيع' %>
                  </span>
                  <span class="inv-badge"><%= item.productCount %> منتج</span>
                </div>
              </div>
              <!-- Action buttons -->
              <div class="inv-card-actions-row" style="width:100%;display:flex;gap:10px;align-items:center;margin-top:10px;padding-top:10px;border-top:1px solid var(--surface-glass-border);">
                <a
                  href="/inventory/<%= sectionSlug %>/<%= item.slug %>"
                  class="inv-btn inv-btn--primary"
                  style="padding:6px 14px;font-size:0.85rem;"
                >عرض المنتجات</a>
                <a
                  href="/inventory/item/<%= item._id %>/edit"
                  class="inv-btn"
                  style="padding:6px 14px;font-size:0.85rem;background:var(--surface-light);color:var(--gray-200);border:1px solid var(--surface-glass-border);"
                >تعديل</a>
                <button
                  type="button"
                  class="inv-btn delete-item-btn"
                  data-action="delete-item"
                  data-item-id="<%= item._id %>"
                  data-item-name="<%= item.name %>"
                  style="padding:6px 14px;font-size:0.85rem;background:var(--error);color:white;"
                >حذف</button>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Pagination -->
        <% if (pages > 1) { %>
          <div class="inv-pagination">
            <% if (page > 1) { %>
              <a href="/inventory/<%= sectionSlug %>?page=<%= page - 1 %>" class="inv-page-btn">&laquo; السابق</a>
            <% } %>
            <% for (let p = 1; p <= pages; p++) { %>
              <a
                href="/inventory/<%= sectionSlug %>?page=<%= p %>"
                class="inv-page-btn<%= p === page ? ' inv-page-btn--active' : '' %>"
              ><%= p %></a>
            <% } %>
            <% if (page < pages) { %>
              <a href="/inventory/<%= sectionSlug %>?page=<%= page + 1 %>" class="inv-page-btn">التالي &raquo;</a>
            <% } %>
          </div>
        <% } %>

      <% } else { %>
        <div class="inv-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 8V21H3V8"/><path d="M1 3H23V8H1V3Z"/><path d="M10 12H14"/></svg>
          <p>لا توجد أصناف في هذا القسم بعد</p>
          <a href="/inventory/add-item?gender=<%= sectionSlug %>" class="inv-btn inv-btn--primary" style="margin-top:16px;">+ إضافة أول صنف</a>
        </div>
      <% } %>
    </section>

  </div>
</main>

<script src="/js/itemList.js"></script>
<%- include('../layouts/footer') %>
