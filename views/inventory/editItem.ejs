<%- include('../layouts/header', { title: title, description: description }) %>

<main class="dashboard-container">
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>

  <div class="category-page" style="width:100%;max-width:700px;margin:0 auto;position:relative;z-index:1;">

    <div class="category-header">
      <nav class="breadcrumb">
        <a href="/dashboard">لوحة التحكم</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory">المخزون</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory/<%= item.gender %>"><%= item.gender === 'men' ? 'رجالي' : item.gender === 'women' ? 'حريمي' : item.gender === 'kids' ? 'أطفال' : item.gender === 'perfumes' ? 'عطور' : 'رياضي' %></a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">تعديل: <%= item.name %></span>
      </nav>
      <h1>تعديل الصنف: <%= item.name %></h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="message-area error" style="display:block;margin-bottom:20px;background:var(--error);color:white;padding:12px 16px;border-radius:8px;">
        <%= error %>
      </div>
    <% } %>

    <section class="dashboard-section">
      <form
        action="/inventory/item/<%= item._id %>/edit?_csrf=<%= csrfToken %>"
        method="POST"
        enctype="multipart/form-data"
        id="editItemForm"
        style="display:flex;flex-direction:column;gap:20px;"
        novalidate
      >

        <!-- Name -->
        <div class="form-group">
          <label for="name" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            اسم الصنف <span style="color:var(--error);">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            maxlength="200"
            value="<%= item.name %>"
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;"
          >
        </div>

        <!-- Season -->
        <div class="form-group">
          <label for="season" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            الموسم <span style="color:var(--error);">*</span>
          </label>
          <select
            id="season"
            name="season"
            required
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;"
          >
            <% [['summer','صيف'],['winter','شتاء'],['autumn','خريف'],['spring','ربيع']].forEach(function(opt){ %>
              <option value="<%= opt[0] %>" <%= item.season === opt[0] ? 'selected' : '' %>><%= opt[1] %></option>
            <% }); %>
          </select>
        </div>

        <!-- Gender is read-only on edit (it's the category grouping) -->
        <div class="form-group">
          <label style="color:var(--gray-50);margin-bottom:8px;display:block;">الفئة</label>
          <input
            type="text"
            readonly
            value="<%= item.gender === 'men' ? 'رجالي' : item.gender === 'women' ? 'حريمي' : item.gender === 'kids' ? 'أطفال' : item.gender === 'perfumes' ? 'عطور' : 'رياضي' %>"
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:var(--gray-400);cursor:not-allowed;"
          >
          <!-- hidden to ensure gender is not accidentally changed -->
        </div>

        <!-- Current Image -->
        <% if (item.image) { %>
          <div class="form-group">
            <label style="color:var(--gray-50);margin-bottom:8px;display:block;">الصورة الحالية</label>
            <img
              src="<%= item.image %>"
              alt="صورة الصنف"
              style="max-width:160px;border-radius:8px;border:1px solid var(--surface-glass-border);"
            >
          </div>
        <% } %>

        <!-- Replace Image -->
        <div class="form-group">
          <label for="image" style="color:var(--gray-50);margin-bottom:8px;display:block;">
            استبدال الصورة (اختياري — أقصى حجم 1 ميجابايت)
          </label>
          <input
            type="file"
            id="image"
            name="image"
            accept="image/*"
            style="width:100%;padding:12px;border-radius:8px;background:var(--surface-light);border:1px solid var(--surface-glass-border);color:white;cursor:pointer;"
          >
          <div id="imagePreview" style="margin-top:10px;display:none;">
            <img id="previewImg" src="" alt="معاينة جديدة" style="max-width:160px;border-radius:8px;border:1px solid var(--surface-glass-border);">
          </div>
        </div>

        <div style="display:flex;gap:12px;">
          <button
            type="submit"
            style="flex:1;background:var(--primary);color:white;border:none;padding:16px;border-radius:8px;font-weight:bold;cursor:pointer;font-size:1rem;"
          >
            حفظ التغييرات
          </button>
          <a
            href="/inventory/<%= item.gender %>"
            style="flex:1;display:flex;align-items:center;justify-content:center;background:var(--surface-light);color:var(--gray-300);border:1px solid var(--surface-glass-border);padding:16px;border-radius:8px;text-decoration:none;font-weight:bold;"
          >
            إلغاء
          </a>
        </div>

      </form>
    </section>
  </div>
</main>

<script nonce="<%= nonce %>">
  document.getElementById('image').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    if (!file.type.startsWith('image/')) {
      alert('يجب أن يكون الملف صورة');
      this.value = '';
      return;
    }
    if (file.size > 1 * 1024 * 1024) {
      alert('حجم الصورة يجب أن يكون أقل من 1 ميجابايت');
      this.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = function (e) {
      document.getElementById('previewImg').src = e.target.result;
      document.getElementById('imagePreview').style.display = 'block';
    };
    reader.readAsDataURL(file);
  });
</script>

<%- include('../layouts/footer') %>
