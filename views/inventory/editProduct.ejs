<%- include('../layouts/header', { title: title, description: description }) %>

<main class="dashboard-container">
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>

  <div class="category-page" style="width: 100%; max-width: 800px; margin: 0 auto; position: relative; z-index: 1;">
    <div class="category-header">
      <nav class="breadcrumb">
        <a href="/dashboard">لوحة التحكم</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory">المخزون</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory/<%= sectionSlug %>"><%= sectionLabel %></a>
        <span class="breadcrumb-sep">/</span>
        <a href="/inventory/<%= sectionSlug %>/<%= categorySlug %>"><%= item.name %></a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">تعديل: <%= product.name %></span>
      </nav>
      <h1>تعديل المنتج: <%= product.name %></h1>
      <p style="color: var(--gray-400); margin-top: 8px;">القسم: <%= sectionLabel %> | الصنف: <%= item.name %></p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="message-area error" style="display: block; margin-bottom: 20px; background: var(--error); color: white; padding: 12px; border-radius: 8px;">
        <%= error %>
      </div>
    <% } %>

    <section class="dashboard-section">
      <form action="/inventory/<%= sectionSlug %>/<%= categorySlug %>/products/<%= product._id %>/edit?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" id="editProductForm" style="display: flex; flex-direction: column; gap: 20px;">
        <!-- Hidden itemId field - maintained from URL -->
        <input type="hidden" name="itemId" value="<%= item._id %>">

        <div class="form-group">
          <label for="name" style="color: var(--gray-50); margin-bottom: 8px; display: block;">اسم المنتج *</label>
          <input type="text" id="name" name="name" required value="<%= product.name %>" style="width: 100%; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;" placeholder="أدخل اسم المنتج">
        </div>

        <div class="form-group">
          <label for="description" style="color: var(--gray-50); margin-bottom: 8px; display: block;">الوصف *</label>
          <textarea id="description" name="description" required rows="4" style="width: 100%; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;" placeholder="أدخل وصف المنتج"><%= product.description %></textarea>
        </div>

        <div class="form-group">
          <label style="color: var(--gray-50); margin-bottom: 8px; display: block;">المقاسات والكمية (Sizes & Quantities)</label>
          <div style="display: flex; gap: 10px; margin-bottom: 15px; align-items: center;">
            <input type="text" id="sizeInput" placeholder="المقاس (مثال: XL)" style="flex: 1; min-width: 100px; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;">
            <input type="number" id="qtyInput" placeholder="الكمية" min="1" step="1" style="width: 100px; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;">
            <button type="button" id="addSizeBtn" style="background: var(--primary); color: white; padding: 12px 20px; border-radius: 8px; border: none; cursor: pointer; font-weight: bold; white-space: nowrap;">إضافة مقاس</button>
          </div>
          <!-- UI List for displaying added sizes -->
          <div id="sizesList" data-existing-sizes='<%- JSON.stringify(product.sizes || []).replace(/'/g, "&apos;") %>' style="display: flex; flex-direction: column; gap: 8px;"></div>
          <!-- Hidden container for actual form inputs -->
          <div id="sizesHiddenInputs"></div>
        </div>

        <div style="display: flex; gap: 20px;">
          <div class="form-group" style="flex: 1;">
            <label for="price" style="color: var(--gray-50); margin-bottom: 8px; display: block;">السعر *</label>
            <input type="number" id="price" name="price" step="0.01" min="0" required value="<%= product.price %>" style="width: 100%; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;" placeholder="0.00">
          </div>

          <div class="form-group" style="flex: 1;">
            <label for="discount" style="color: var(--gray-50); margin-bottom: 8px; display: block;">الخصم</label>
            <input type="number" id="discount" name="discount" step="0.01" min="0" value="<%= product.discount || 0 %>" style="width: 100%; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white;" placeholder="0.00 (اختياري)">
          </div>
        </div>

        <!-- Current Images with delete checkboxes -->
        <div class="form-group">
          <label style="color: var(--gray-50); margin-bottom: 8px; display: block;">الصور الحالية</label>
          <div id="currentImages" style="display: flex; gap: 16px; flex-wrap: wrap;">
            <% if (product.images && product.images.length > 0) { %>
              <% product.images.forEach(function(imgPath, index) { %>
                <div class="edit-image-thumb">
                  <img src="<%= imgPath %>" alt="صورة المنتج">
                  <label>
                    <input type="checkbox" class="image-remove-checkbox" data-filename="<%= imgPath.split('/').pop() %>">
                    حذف هذه الصورة
                  </label>
                </div>
              <% }) %>
            <% } else { %>
              <span style="color: var(--gray-500);">لا توجد صور حالياً</span>
            <% } %>
          </div>
        </div>

        <!-- Hidden field for images to remove -->
        <input type="hidden" name="imagesToRemove" id="imagesToRemoveHidden" value="">

        <!-- Upload new images -->
        <div class="form-group">
          <label for="images" style="color: var(--gray-50); margin-bottom: 8px; display: block;">إضافة صور جديدة (أقصى حجم إجمالي 5MB)</label>
          <input type="file" id="images" name="images" multiple accept="image/*" style="width: 100%; padding: 12px; border-radius: 8px; background: var(--surface-light); border: 1px solid var(--surface-glass-border); color: white; cursor: pointer;">
        </div>

        <button type="submit" id="submitBtn" style="background: var(--primary); color: white; border: none; padding: 16px; border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 20px; font-size: 1.1rem;">حفظ التغييرات</button>
      </form>
    </section>
  </div>

<script src="/js/inventory.js"></script>
<script src="/js/editProduct.js"></script>
<%- include('../layouts/footer') %>
