<%- include('../layouts/header', { title: title, description: description }) %>

<main class="dashboard-container">
  <div class="bg-orb bg-orb--1"></div>
  <div class="bg-orb bg-orb--2"></div>

  <div class="inv-page" style="width:100%;max-width:900px;margin:0 auto;position:relative;z-index:1;">

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/dashboard">لوحة التحكم</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">المخزون</span>
    </nav>

    <!-- Page Header -->
    <div class="inv-page-header">
      <div>
        <h1 class="inv-page-title">المخزون</h1>
        <p class="inv-page-subtitle">إدارة الأقسام والأصناف والمنتجات</p>
      </div>
      <a href="/inventory/add-item" class="inv-btn inv-btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        إضافة صنف
      </a>
    </div>

    <!-- Sections Grid -->
    <section class="inv-section">
      <div class="inv-section-header">
        <h2 class="inv-section-title">الأقسام</h2>
        <span class="inv-count"><%= sections.length %> قسم</span>
      </div>

      <% if (sections && sections.length > 0) { %>
        <div class="inv-grid inv-grid--3">
          <% sections.forEach(function(s) { %>
            <a href="/inventory/<%= s.slug %>" class="inv-card inv-card--section">
              <div class="inv-card-body">
                <span class="inv-card-title"><%= s.label %></span>
                <div class="inv-card-meta">
                  <span class="inv-badge"><%= s.itemCount %> صنف</span>
                  <span class="inv-badge inv-badge--muted"><%= s.productCount %> منتج</span>
                </div>
              </div>
              <div class="inv-card-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="inv-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          <p>لا توجد أقسام بعد</p>
        </div>
      <% } %>
    </section>

  </div>
</main>

<%- include('../layouts/footer') %>
